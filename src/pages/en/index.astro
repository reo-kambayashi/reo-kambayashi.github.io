---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HeroSection from '../../components/sections/HeroSection.astro';
import AboutSection from '../../components/sections/AboutSection.astro';
import PublicationsSection from '../../components/sections/PublicationsSection.astro';
import AwardsSection from '../../components/sections/AwardsSection.astro';
import EducationSection from '../../components/sections/EducationSection.astro';
import ContactSection from '../../components/sections/ContactSection.astro';
import {
  siteMeta,
  profileSummary,
  about,
  publications,
  awards,
  educationHistory,
  contacts,
  contactIcons,
  resolveLocalizedText,
} from '../../data/profile';

const locale = 'en';
const title = resolveLocalizedText(siteMeta.title, locale);
const description = resolveLocalizedText(siteMeta.description, locale);
---
<SiteLayout locale={locale} title={title} description={description}>
  <HeroSection locale={locale} profileSummary={profileSummary} />
  <AboutSection locale={locale} about={about} />
  <PublicationsSection
    locale={locale}
    publications={publications}
    selfName={profileSummary.selfName}
  />
  <AwardsSection locale={locale} awards={awards} />
  <EducationSection locale={locale} educationHistory={educationHistory} />
  <ContactSection locale={locale} contacts={contacts} contactIcons={contactIcons} />
</SiteLayout>
