---
import { readdirSync } from 'node:fs';
import { join } from 'node:path';
import type { StudyArticle } from '../../data/types';
import {
  formatPublishedDate,
  resolveAssetPath,
  studyPageContent,
} from '../../data/studyArticles';

type Props = {
  article: StudyArticle;
};

const { article } = Astro.props as Props;
const basePath = import.meta.env.BASE_URL;
const pdfHref = resolveAssetPath(basePath, article.pdfPath);
const listPath = `${basePath.replace(/\/$/, '')}/study/competitive-programming`;

const svgDirPath = article.pdfPath.replace(/\.pdf$/, '-svg');
const svgAbsDir = join(process.cwd(), 'public', svgDirPath);
let svgPages: string[] = [];
try {
  svgPages = readdirSync(svgAbsDir)
    .filter((f) => f.endsWith('.svg'))
    .sort()
    .map((f) => resolveAssetPath(basePath, `${svgDirPath}/${f}`));
} catch {
  svgPages = [];
}
---
<section aria-labelledby="study-article-heading">
  <header class="article-header">
    <h2 id="study-article-eyebrow">Article</h2>
    <h1 id="study-article-heading">{article.title}</h1>
    <div class="article-meta">
      <span class="meta-label">{studyPageContent.publishedLabel}</span>
      <time datetime={article.publishedAt}>
        {formatPublishedDate(article.publishedAt)}
      </time>
      {article.tags.length > 0 && (
        <ul class="article-tags" aria-label={studyPageContent.tagsLabel}>
          {article.tags.map((tag) => (
            <li class="article-tag">{tag}</li>
          ))}
        </ul>
      )}
    </div>
    {article.description && <p class="description">{article.description}</p>}
  </header>

  <div class="pdf-pages" aria-label={article.title}>
    {svgPages.length > 0 ? (
      svgPages.map((src, i) => (
        <img
          class="pdf-page"
          src={src}
          alt={`${article.title} - page ${i + 1}`}
          loading={i < 2 ? 'eager' : 'lazy'}
          decoding="async"
        />
      ))
    ) : (
      <p class="pdf-status">
        スライドを表示できません。<a href={pdfHref} target="_blank" rel="noopener">PDF を開く</a>。
      </p>
    )}
  </div>

  <div class="article-actions">
    <a class="action-link primary" href={pdfHref} download>
      {studyPageContent.downloadLabel}
    </a>
    <a class="action-link" href={pdfHref} target="_blank" rel="noopener">
      {studyPageContent.openInNewTab}
    </a>
    <a class="action-link subtle" href={listPath}>
      ← {studyPageContent.backToList}
    </a>
  </div>
</section>

<style>
  .article-header {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.85rem;
    color: var(--muted);
    font-size: clamp(0.84rem, 0.8rem + 0.12vw, 0.94rem);
  }

  .meta-label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .article-tag {
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }

  .description {
    color: var(--text);
    max-width: var(--reading-max, 44em);
    font-size: clamp(0.98rem, 0.94rem + 0.18vw, 1.12rem);
    word-break: auto-phrase;
    line-break: strict;
  }

  .pdf-pages {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
  }

  .pdf-pages .pdf-page {
    width: 100%;
    height: auto;
    display: block;
    background: var(--surface-soft);
    box-shadow: var(--shadow-sm);
  }

  .pdf-status {
    color: var(--muted);
    font-size: 0.9rem;
    padding: 1rem 0;
  }

  .article-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: center;
  }

  .action-link {
    display: inline-flex;
    align-items: center;
    padding: clamp(0.45rem, 0.4vw + 0.35rem, 0.6rem) clamp(0.9rem, 0.6vw + 0.7rem, 1.2rem);
    border: 1px solid var(--border);
    border-radius: 2px;
    color: var(--text);
    font-size: clamp(0.86rem, 0.82rem + 0.14vw, 0.98rem);
    text-decoration: none;
    transition: border-color 150ms ease, color 150ms ease, background 150ms ease;
  }

  .action-link:hover,
  .action-link:focus-visible {
    border-color: var(--accent);
    color: var(--accent-strong);
  }

  .action-link.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: #ffffff;
  }

  .action-link.primary:hover,
  .action-link.primary:focus-visible {
    background: var(--accent-strong);
    border-color: var(--accent-strong);
    color: #ffffff;
  }

  .action-link.subtle {
    border-color: transparent;
    color: var(--muted);
  }

  .action-link.subtle:hover,
  .action-link.subtle:focus-visible {
    color: var(--text-strong);
    border-color: transparent;
  }
</style>
