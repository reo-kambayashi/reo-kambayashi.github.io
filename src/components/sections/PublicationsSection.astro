---
import {
  publicationSectionContent,
  resolveLocalizedText,
  type Locale,
  type Publication,
} from '../../data/profile';

type Props = {
  locale: Locale;
  publications: Publication[];
  selfName?: string;
};

const { locale, publications, selfName } = Astro.props as Props;
const heading = resolveLocalizedText(publicationSectionContent.heading, locale);
const emptyMessage = resolveLocalizedText(publicationSectionContent.empty, locale);
const authorSeparator = resolveLocalizedText(publicationSectionContent.authorSeparator, locale);
---
<section
  id="research"
  class="scroll-fade"
  aria-labelledby="research-heading"
  data-animate="fade-up"
  data-animate-stagger="80"
  data-animate-translate-y="10px"
  data-animate-duration="420ms"
>
  <div class="section-header section-header--rule">
    <h2 id="research-heading">{heading}</h2>
    <div class="section-rule" aria-hidden="true"></div>
  </div>
  <div class="publication-list">
    {publications.length > 0 ? (
      publications.map((pub) => (
        <article class="publication-item" data-animate-item>
          <h3 class="pub-title">{resolveLocalizedText(pub.title, locale)}</h3>
          <p class="pub-authors">
            {pub.authors.map((author, index) => (
              <>
                {index > 0 && authorSeparator}
                {selfName && author === selfName ? <strong>{author}</strong> : author}
              </>
            ))}
          </p>
          <p class="pub-meta">
            <span class="pub-venue">{resolveLocalizedText(pub.venue, locale)}</span>
            {pub.type && <span class="pub-type">{resolveLocalizedText(pub.type, locale)}</span>}
          </p>
          {pub.note && <p class="pub-note">{resolveLocalizedText(pub.note, locale)}</p>}
          {pub.links && pub.links.length > 0 && (
            <ul class="pub-links">
              {pub.links.map((link) => (
                <li>
                  <a href={link.href} target="_blank" rel="noopener noreferrer">
                    {resolveLocalizedText(link.label, locale)}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </article>
      ))
    ) : (
      <p class="pub-empty">{emptyMessage}</p>
    )}
  </div>
</section>

<style>
  .publication-list {
    display: flex;
    flex-direction: column;
  }

  .publication-item {
    display: grid;
    gap: 0.45rem;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--border);
    transition: none;
  }

  .publication-item:first-child {
    padding-top: 0.2rem;
  }

  .pub-title {
    transition: color 120ms ease;
  }

  .publication-item:hover .pub-title {
    color: var(--muted);
  }

  .pub-authors {
    margin: 0;
    color: var(--text);
    font-size: 0.93rem;
    line-height: 1.7;
  }

  .pub-authors strong {
    font-weight: 700;
    color: var(--text-strong);
  }

  .pub-meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.75rem;
    font-size: 0.88rem;
  }

  .pub-venue {
    color: var(--muted);
  }

  .pub-type {
    color: var(--muted);
    font-size: 0.83rem;
    border: 1px solid var(--border);
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
  }

  .pub-note {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-strong);
  }

  .pub-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin-top: 0.1rem;
  }

  .pub-links a {
    font-size: 0.88rem;
    font-weight: 500;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
    color: var(--muted);
    transition: color 120ms ease;
  }

  .pub-links a:hover {
    color: var(--text-strong);
  }

  .pub-empty {
    color: var(--muted);
  }
</style>
