---
import type { StudyArticle } from '../../data/types';
import { formatPublishedDate, studyPageContent } from '../../data/studyArticles';

type Props = {
  articles: StudyArticle[];
};

const { articles } = Astro.props as Props;
const sorted = [...articles].sort((a, b) =>
  a.publishedAt < b.publishedAt ? 1 : a.publishedAt > b.publishedAt ? -1 : 0
);
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const buildArticlePath = (slug: string) => `${basePath}/study/competitive-programming/${slug}`;
---
<section aria-labelledby="study-list-heading">
  <header class="section-header">
    <h2 id="study-list-heading">Articles</h2>
    <h1>{studyPageContent.categoryTitle}</h1>
  </header>
  <p class="lead">{studyPageContent.categoryLead}</p>

  {sorted.length === 0 ? (
    <p class="empty">{studyPageContent.empty}</p>
  ) : (
    <ol class="article-list">
      {sorted.map((article) => (
        <li class="article-item">
          <a class="article-link" href={buildArticlePath(article.slug)}>
            <h3 class="article-title">
              <span class="article-title-text">{article.title}</span>
              <span class="article-link-arrow" aria-hidden="true">→</span>
            </h3>
            <div class="article-meta">
              <time datetime={article.publishedAt}>
                {formatPublishedDate(article.publishedAt)}
              </time>
              {article.tags.length > 0 && (
                <ul class="article-tags" aria-label={studyPageContent.tagsLabel}>
                  {article.tags.map((tag) => (
                    <li class="article-tag">{tag}</li>
                  ))}
                </ul>
              )}
            </div>
            <p class="article-description">{article.description}</p>
          </a>
        </li>
      ))}
    </ol>
  )}
</section>

<style>
  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .lead {
    color: var(--muted);
    max-width: var(--reading-max, 44em);
    font-size: clamp(0.98rem, 0.94rem + 0.16vw, 1.1rem);
    word-break: auto-phrase;
    line-break: strict;
  }

  .empty {
    color: var(--muted);
    font-style: italic;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-item {
    border-top: 1px solid var(--border);
  }

  .article-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .article-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: clamp(1rem, 1.4vw, 1.4rem) clamp(0.6rem, 1vw, 1rem);
    margin-inline: calc(-1 * clamp(0.6rem, 1vw, 1rem));
    color: inherit;
    text-decoration: none;
    border-radius: 0.5rem;
    transition: background-color 150ms ease;
  }

  .article-link:hover,
  .article-link:focus-visible {
    background-color: var(--accent-light);
  }

  .article-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .article-title {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--accent-strong);
    transition: color 150ms ease;
  }

  .article-title-text {
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--accent) 35%, transparent);
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1.5px;
    transition: text-decoration-color 150ms ease;
  }

  .article-link:hover .article-title-text,
  .article-link:focus-visible .article-title-text {
    text-decoration-color: var(--accent-strong);
  }

  .article-link-arrow {
    color: var(--accent);
    font-weight: 600;
    transition: transform 150ms ease;
    display: inline-block;
  }

  .article-link:hover .article-link-arrow,
  .article-link:focus-visible .article-link-arrow {
    transform: translateX(0.25rem);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.85rem;
    color: var(--muted);
    font-size: clamp(0.8rem, 0.76rem + 0.12vw, 0.9rem);
  }


  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .article-tag {
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }

  .article-description {
    color: var(--text);
    max-width: var(--reading-max, 44em);
    font-size: clamp(0.96rem, 0.92rem + 0.16vw, 1.08rem);
  }
</style>
