---
import type { StudyArticle } from '../../data/types';
import { formatPublishedDate, studyPageContent } from '../../data/studyArticles';

type Props = {
  articles: StudyArticle[];
};

const { articles } = Astro.props as Props;
const sorted = [...articles].sort((a, b) =>
  a.publishedAt < b.publishedAt ? 1 : a.publishedAt > b.publishedAt ? -1 : 0
);
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const buildArticlePath = (slug: string) => `${basePath}/study/competitive-programming/${slug}`;
---
<section aria-labelledby="study-list-heading">
  <header class="section-header">
    <h2 id="study-list-heading">Articles</h2>
    <h1>{studyPageContent.categoryTitle}</h1>
  </header>
  <p class="lead">{studyPageContent.categoryLead}</p>

  {sorted.length === 0 ? (
    <p class="empty">{studyPageContent.empty}</p>
  ) : (
    <ol class="article-list">
      {sorted.map((article) => (
        <li class="article-item">
          <a class="article-link" href={buildArticlePath(article.slug)}>
            <h3 class="article-title">{article.title}</h3>
            <div class="article-meta">
              <time datetime={article.publishedAt}>
                {formatPublishedDate(article.publishedAt)}
              </time>
              {article.tags.length > 0 && (
                <ul class="article-tags" aria-label={studyPageContent.tagsLabel}>
                  {article.tags.map((tag) => (
                    <li class="article-tag">{tag}</li>
                  ))}
                </ul>
              )}
            </div>
            <p class="article-description">{article.description}</p>
          </a>
        </li>
      ))}
    </ol>
  )}
</section>

<style>
  .section-header {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .lead {
    color: var(--muted);
    max-width: 60ch;
  }

  .empty {
    color: var(--muted);
    font-style: italic;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-item {
    border-top: 1px solid var(--border);
  }

  .article-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .article-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.15rem 0;
    color: inherit;
    text-decoration: none;
  }

  .article-link:hover .article-title,
  .article-link:focus-visible .article-title {
    color: var(--accent-strong);
  }

  .article-title {
    transition: color 150ms ease;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.85rem;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .article-tag {
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: var(--accent-light);
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
  }

  .article-description {
    color: var(--text);
  }
</style>
