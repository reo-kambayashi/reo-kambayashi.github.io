---
import { Image } from 'astro:assets';
import yansCertificate from '../../assets/YANS_certificate.jpg';
import ipsjCertificate from '../../assets/IPSJ_certificate.jpg';
import {
  awardSectionContent,
  resolveLocalizedText,
  type Award,
  type Locale,
} from '../../data/profile';

type Props = {
  locale: Locale;
  awards: Award[];
};

const { locale, awards } = Astro.props as Props;
const certificateImages = {
  yans: yansCertificate,
  ipsj: ipsjCertificate,
};
const heading = resolveLocalizedText(awardSectionContent.heading, locale);
const targetLabel = resolveLocalizedText(awardSectionContent.targetLabel, locale);
const emptyMessage = resolveLocalizedText(awardSectionContent.empty, locale);
const defaultCertificateAlt = resolveLocalizedText(awardSectionContent.defaultCertificateAlt, locale);
---
<section
  id="awards"
  class="scroll-fade"
  aria-labelledby="awards-heading"
  data-animate="fade-up"
  data-animate-stagger="90"
  data-animate-translate-y="14px"
  data-animate-duration="420ms"
>
  <div class="section-header section-header--rule">
    <h2 id="awards-heading">{heading}</h2>
    <div class="section-rule" aria-hidden="true"></div>
  </div>
  <div class="award-list">
    {awards.length > 0 ? (
      awards.map((award) => {
        const certificate =
          award.certificateImage ? certificateImages[award.certificateImage] : undefined;

        return (
          <article class="award-item" data-animate-item>
            <div class="award-body">
              <h3 class="award-title">{resolveLocalizedText(award.title, locale)}</h3>
              {award.targetTitle && (
                <p class="award-detail">
                  <span class="award-detail-label">{targetLabel}:</span>{' '}
                  {resolveLocalizedText(award.targetTitle, locale)}
                </p>
              )}
              {award.result && (
                <p class="award-detail award-detail--result">
                  {resolveLocalizedText(award.result, locale)}
                </p>
              )}
            </div>
            {certificate && (
              <div class="award-certificate">
                <Image
                  src={certificate}
                  alt={
                    award.certificateAlt
                      ? resolveLocalizedText(award.certificateAlt, locale)
                      : defaultCertificateAlt
                  }
                  width={144}
                  densities={[1.5, 2, 3]}
                  class="award-certificate-image"
                />
              </div>
            )}
          </article>
        );
      })
    ) : (
      <p class="award-empty">{emptyMessage}</p>
    )}
  </div>
</section>

<style>
  .award-list {
    display: flex;
    flex-direction: column;
  }

  .award-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.25rem;
    align-items: start;
    padding: 1.4rem 0 1.4rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .award-item:first-child {
    padding-top: 0.2rem;
  }

  .award-body {
    display: grid;
    gap: 0.4rem;
    min-width: 0;
  }

  .award-title {
    margin: 0;
    position: relative;
  }

  .award-title::before {
    content: '';
    position: absolute;
    left: -1.15rem;
    top: 0.75em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .award-detail {
    margin: 0;
    font-size: clamp(0.92rem, 0.88rem + 0.14vw, 1.02rem);
    color: var(--muted);
    line-height: 1.75;
  }

  .award-detail-label {
    color: var(--text);
    font-weight: 500;
  }

  .award-detail--result {
    color: var(--accent);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.85rem;
  }

  .award-certificate {
    width: clamp(6rem, 5vw + 4rem, 9rem);
    flex-shrink: 0;
  }

  .award-certificate-image {
    width: 100%;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--border);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .award-certificate-image:hover {
    transform: scale(1.03);
    box-shadow: var(--shadow-lg);
  }

  .award-empty {
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .award-item {
      grid-template-columns: 1fr;
      gap: 0.8rem;
      padding: 1.2rem 0 1.2rem 1.5rem;
    }

    .award-detail {
      font-size: 0.91rem;
    }

    .award-certificate {
      width: 5.5rem;
      justify-self: start;
    }
  }

  @media (min-width: 641px) {
    .award-detail {
      max-width: var(--reading-max, 42rem);
    }
  }
</style>
