---
import { Image } from 'astro:assets';
import yansCertificate from '../../assets/YANS_certificate.jpg';
import type { Award } from '../../data/profile';

type Props = {
  awards: Award[];
};

const { awards } = Astro.props as Props;
const certificateImages = {
  yans: yansCertificate,
};
---
<section id="awards" aria-labelledby="awards-heading">
  <div class="section-header section-header--rule">
    <h2 id="awards-heading">受賞</h2>
    <div class="section-rule" aria-hidden="true"></div>
  </div>
  <div class="award-list">
    {awards.length > 0 ? (
      awards.map((award) => {
        const certificate =
          award.certificateImage ? certificateImages[award.certificateImage] : undefined;

        return (
          <article class="award-item surface-card">
            <div class="award-body">
              <h3 class="award-title">{award.title}</h3>
              {award.targetTitle && (
                <p class="award-detail">
                  <span class="award-detail-label">対象発表:</span> {award.targetTitle}
                </p>
              )}
              {award.result && <p class="award-detail award-detail--result">{award.result}</p>}
            </div>
            {certificate && (
              <div class="award-certificate">
                <Image
                  src={certificate}
                  alt={award.certificateAlt ?? '受賞賞状'}
                  width={112}
                  class="award-certificate-image"
                />
              </div>
            )}
          </article>
        );
      })
    ) : (
      <p class="award-empty">受賞情報は現在準備中です。</p>
    )}
  </div>
</section>

<style>
  .award-list {
    display: grid;
    gap: 1rem;
  }

  .award-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.25rem;
    align-items: start;
    padding: 1.25rem 1.3rem;
  }

  .award-body {
    display: grid;
    gap: 0.45rem;
    min-width: 0;
  }

  .award-title {
    margin: 0;
    font-weight: 700;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text);
  }

  .award-detail {
    margin: 0;
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.75;
  }

  .award-detail-label {
    color: var(--text);
    font-weight: 600;
  }

  .award-detail--result {
    color: var(--accent);
    font-weight: 600;
  }

  .award-certificate {
    width: 7.1rem;
    flex-shrink: 0;
  }

  .award-certificate-image {
    width: 100%;
    height: auto;
    border-radius: 12px;
    border: 1px solid rgba(61, 111, 180, 0.14);
  }

  .award-empty {
    color: var(--muted);
  }

  @media (max-width: 640px) {
    .award-item {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .award-certificate {
      width: 5.5rem;
    }
  }

  @media (min-width: 641px) {
    .award-detail {
      max-width: 42rem;
    }
  }
</style>
