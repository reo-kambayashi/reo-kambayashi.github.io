---
import { Image } from 'astro:assets';
import logo from '../../assets/logo-desktop-dark+.svg';

type Props = {
  profileSummary: {
    name: string;
    affiliationLabel: string;
    affiliationValue: string;
    researchAreaLabel: string;
    researchAreaValue: string;
  };
};

const { profileSummary } = Astro.props as Props;
---
<section id="top" class="hero" aria-labelledby="hero-name">
  <div class="hero-shell">
    <div class="hero-heading">
      <div class="hero-logo-wrap">
        <Image src={logo} alt="Tohoku NLP Group" class="hero-logo" width={90} height={81} />
      </div>
      <div class="hero-copy">
        <p class="hero-kicker">プロフィール</p>
        <h1 id="hero-name" class="hero-name">{profileSummary.name}</h1>
        <dl class="hero-meta" aria-label="基本情報">
          <div class="hero-meta-row surface-card">
            <dt>{profileSummary.affiliationLabel}</dt>
            <dd class="hero-meta-value hero-meta-value--nowrap">{profileSummary.affiliationValue}</dd>
          </div>
          <div class="hero-meta-row surface-card">
            <dt>{profileSummary.researchAreaLabel}</dt>
            <dd class="hero-meta-value">{profileSummary.researchAreaValue}</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(1.9rem, 4vw, 3rem);
    padding-bottom: clamp(1.7rem, 4vw, 2.8rem);
  }

  .hero-shell {
    display: flex;
    align-items: flex-start;
    width: 100%;
    padding: clamp(1rem, 2vw, 1.55rem);
    background: var(--surface);
    border: 1px solid rgba(61, 111, 180, 0.12);
    border-radius: 22px;
  }

  .hero-heading {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.4vw, 1.6rem);
    min-width: 0;
    width: 100%;
  }

  .hero-logo-wrap {
    width: clamp(5rem, 10vw, 6.2rem);
    flex-shrink: 0;
    padding: 0.8rem;
    background: rgba(244, 248, 255, 0.98);
    border: 1px solid rgba(61, 111, 180, 0.14);
    border-radius: 20px;
  }

  .hero-logo {
    width: 100%;
    height: auto;
  }

  .hero-copy {
    flex: 1 1 auto;
    display: grid;
    gap: 0.9rem;
    min-width: 0;
  }

  .hero-kicker {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--accent);
  }

  .hero-name {
    font-size: clamp(2.3rem, 4.6vw, 3.4rem);
    line-height: 1.15;
  }

  .hero-meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
  }

  .hero-meta-row {
    display: grid;
    grid-template-columns: minmax(3.4rem, auto) minmax(0, 1fr);
    align-items: center;
    gap: 0.35rem 1rem;
    min-width: 0;
    padding: 0.95rem 1rem;
  }

  .hero-meta dt {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.08em;
    line-height: 1.4;
  }

  .hero-meta-value {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.6;
    color: var(--text);
    word-break: keep-all;
    overflow-wrap: normal;
  }

  .hero-meta-value--nowrap {
    font-size: clamp(0.82rem, 0.77rem + 0.24vw, 0.95rem);
    line-height: 1.6;
    white-space: nowrap;
  }

  @media (max-width: 820px) {
    .hero-heading {
      align-items: flex-start;
    }
  }

  @media (max-width: 720px) {
    .hero {
      padding-top: 1.45rem;
      padding-bottom: 1.35rem;
    }

    .hero-shell {
      padding: 0.95rem;
      border-radius: 18px;
    }

    .hero-name {
      font-size: clamp(2.05rem, 10vw, 2.65rem);
    }

    .hero-meta-row {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 0.24rem;
      padding: 0.85rem 0.9rem;
    }

    .hero-meta-value--nowrap {
      white-space: normal;
    }
  }

  @media (max-width: 560px) {
    .hero-heading {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.8rem;
    }

    .hero-logo-wrap {
      width: 4.4rem;
      padding: 0.62rem;
    }

    .hero-copy {
      gap: 0.68rem;
    }

    .hero-kicker {
      font-size: 0.74rem;
      letter-spacing: 0.14em;
    }
  }

  @media (max-width: 420px) {
    .hero-shell {
      padding: 0.85rem;
    }

    .hero-meta {
      gap: 0.7rem;
    }

    .hero-meta-value {
      font-size: 0.93rem;
    }
  }
</style>
