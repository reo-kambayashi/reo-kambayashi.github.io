---
import { Image } from 'astro:assets';
import logo from '../../assets/logo-desktop-dark+.svg';
import {
  resolveLocalizedText,
  type Locale,
  type ProfileSummary,
} from '../../data/profile';

type Props = {
  locale: Locale;
  profileSummary: ProfileSummary;
};

const { locale, profileSummary } = Astro.props as Props;
const name = resolveLocalizedText(profileSummary.name, locale);
const heroLogoAlt = resolveLocalizedText(profileSummary.heroLogoAlt, locale);
const affiliationValue = resolveLocalizedText(profileSummary.affiliationValue, locale);
const researchAreaValue = resolveLocalizedText(profileSummary.researchAreaValue, locale);
---
<section id="top" class="hero" aria-labelledby="hero-name">
  <div
    class="hero-inner scroll-fade"
    data-animate="fade-up"
    data-animate-translate-y="12px"
    data-animate-duration="560ms"
    data-animate-stagger="100"
  >
    <div class="hero-eyebrow" data-animate-item>
      <Image src={logo} alt={heroLogoAlt} class="hero-logo" width={34} height={31} />
      <span class="hero-kicker">{researchAreaValue}</span>
    </div>
    <h1 id="hero-name" class="hero-name" data-animate-item>{name}</h1>
    <p class="hero-affiliation" data-animate-item>{affiliationValue}</p>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(1.8rem, 4vw, 3rem);
    padding-bottom: clamp(1.6rem, 3.5vw, 2.6rem);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: clamp(0.9rem, 2vw, 1.4rem);
  }

  .hero-logo {
    width: 30px;
    height: auto;
    opacity: 0.75;
    flex-shrink: 0;
  }

  .hero-kicker {
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 6vw, 3.8rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-strong);
    margin: 0 0 clamp(0.6rem, 1.5vw, 0.9rem);
  }

  .hero-affiliation {
    font-size: clamp(0.88rem, 0.86rem + 0.16vw, 0.96rem);
    color: var(--muted);
    line-height: 1.75;
    margin: 0;
    letter-spacing: 0.01em;
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 1.5rem;
      padding-bottom: 1.4rem;
    }

    .hero-name {
      font-size: clamp(2rem, 11vw, 2.6rem);
    }
  }
</style>
