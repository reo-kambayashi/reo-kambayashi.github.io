---
import { Image } from 'astro:assets';
import logo from '../../assets/logo-desktop-dark+.svg';

type Props = {
  profileSummary: {
    name: string;
    affiliationLabel: string;
    affiliationValue: string;
    researchAreaLabel: string;
    researchAreaValue: string;
  };
};

const { profileSummary } = Astro.props as Props;
---
<section id="top" class="hero" aria-labelledby="hero-name">
  <div class="hero-shell">
    <div class="hero-mark">
      <div class="hero-logo-wrap">
        <Image src={logo} alt="Tohoku NLP Group" class="hero-logo" width={90} height={81} />
      </div>
      <p class="hero-mark-label">坂口・乾研究室</p>
    </div>
    <div class="hero-copy">
      <p class="hero-kicker">プロフィール</p>
      <div class="hero-title-block">
        <h1 id="hero-name" class="hero-name">{profileSummary.name}</h1>
        <p class="hero-affiliation">
          <span class="hero-affiliation-label">{profileSummary.affiliationLabel}</span>
          <span class="hero-affiliation-value">{profileSummary.affiliationValue}</span>
        </p>
      </div>
      <dl class="hero-meta" aria-label="基本情報">
        <div class="hero-meta-row">
          <dt>{profileSummary.researchAreaLabel}</dt>
          <dd class="hero-meta-value">{profileSummary.researchAreaValue}</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(1.9rem, 4vw, 3rem);
    padding-bottom: clamp(1.7rem, 4vw, 2.8rem);
  }

  .hero-shell {
    display: grid;
    grid-template-columns: clamp(5.8rem, 12vw, 7rem) minmax(0, 1fr);
    gap: clamp(1rem, 2.8vw, 1.8rem);
    align-items: center;
    width: 100%;
    padding: clamp(1rem, 2vw, 1.55rem);
    background: var(--surface);
    border-radius: 22px;
  }

  .hero-mark {
    display: grid;
    justify-items: center;
    gap: 0.55rem;
  }

  .hero-logo-wrap {
    width: 100%;
    padding: 0.8rem;
    background: rgba(255, 255, 255, 0.94);
    border-radius: 20px;
  }

  .hero-logo {
    width: 100%;
    height: auto;
  }

  .hero-mark-label {
    font-size: 0.76rem;
    line-height: 1.5;
    color: var(--muted);
    text-align: center;
    letter-spacing: 0.04em;
  }

  .hero-copy {
    display: grid;
    gap: 0.8rem;
    min-width: 0;
  }

  .hero-kicker {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--accent);
  }

  .hero-name {
    font-size: clamp(2.3rem, 4.6vw, 3.4rem);
    line-height: 1.15;
  }

  .hero-title-block {
    display: grid;
    gap: 0.65rem;
  }

  .hero-affiliation {
    display: grid;
    gap: 0.18rem;
    max-width: 48rem;
  }

  .hero-affiliation-label {
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  .hero-affiliation-value {
    font-size: clamp(0.98rem, 0.95rem + 0.16vw, 1.05rem);
    line-height: 1.8;
    color: var(--text-strong);
  }

  .hero-meta {
    margin: 0;
    padding: 0;
  }

  .hero-meta-row {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    width: fit-content;
    max-width: 100%;
    padding: 0.7rem 0.9rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.82);
  }

  .hero-meta dt {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.08em;
    line-height: 1.4;
  }

  .hero-meta-value {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text);
    word-break: keep-all;
    overflow-wrap: normal;
  }

  @media (max-width: 820px) {
    .hero-shell {
      grid-template-columns: 5.5rem minmax(0, 1fr);
    }
  }

  @media (max-width: 720px) {
    .hero {
      padding-top: 1.45rem;
      padding-bottom: 1.35rem;
    }

    .hero-shell {
      grid-template-columns: 1fr;
      padding: 0.95rem;
      border-radius: 18px;
    }

    .hero-name {
      font-size: clamp(2.05rem, 10vw, 2.65rem);
    }

    .hero-meta-row {
      width: 100%;
      border-radius: 16px;
    }
  }

  @media (max-width: 560px) {
    .hero-mark {
      justify-items: start;
      gap: 0.45rem;
    }

    .hero-logo-wrap {
      width: 4.4rem;
      padding: 0.62rem;
    }

    .hero-copy {
      gap: 0.68rem;
    }

    .hero-kicker {
      font-size: 0.74rem;
      letter-spacing: 0.14em;
    }

    .hero-affiliation-value,
    .hero-meta-value {
      font-size: 0.93rem;
    }
  }

  @media (max-width: 420px) {
    .hero-shell {
      padding: 0.85rem;
    }

    .hero-meta-row {
      padding: 0.72rem 0.82rem;
    }
  }
</style>
