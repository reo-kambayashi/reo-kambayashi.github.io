---
import {
  resolveLocalizedText,
  type About,
  type Locale,
} from '../../data/profile';

type Props = {
  locale: Locale;
  about: About;
};

const { locale, about } = Astro.props as Props;
const heading = resolveLocalizedText(about.heading, locale);
const description = resolveLocalizedText(about.description, locale);
const membershipPrefix = resolveLocalizedText(about.membershipPrefix, locale);
const membershipSuffix = resolveLocalizedText(about.membershipSuffix, locale);
const aboutLeadText =
  locale === 'en' ? `${description} ${membershipPrefix}` : description;
---
<section
  id="about"
  class="scroll-fade"
  aria-labelledby="about-heading"
  data-animate="fade-up"
  data-animate-translate-y="14px"
  data-animate-duration="420ms"
>
  <div class="section-header section-header--rule">
    <h2 id="about-heading">{heading}</h2>
    <div class="section-rule" aria-hidden="true"></div>
  </div>
  <div class="section-body" data-animate-item>
    <p class="about-copy">
      {aboutLeadText}<a href={about.group.href} target="_blank" rel="noopener noreferrer">{about.group.name}</a>{membershipSuffix}
    </p>
  </div>
</section>

<style>
  .about-copy {
    max-width: 48rem;
    font-size: clamp(1.02rem, 0.98rem + 0.32vw, 1.15rem);
    line-height: 1.92;
    color: var(--text-strong);
  }

  .about-copy a {
    white-space: nowrap;
    font-weight: 600;
  }

  @media (max-width: 480px) {
    .about-copy {
      font-size: 1rem;
      line-height: 1.84;
    }

    .about-copy a {
      white-space: normal;
      overflow-wrap: anywhere;
    }
  }
</style>
