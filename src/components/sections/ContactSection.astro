---
import {
  contactSectionContent,
  resolveLocalizedText,
  type Contact,
  type ContactIcon,
  type ContactIconKey,
  type Locale,
} from '../../data/profile';

type Props = {
  locale: Locale;
  contacts: Contact[];
  contactIcons: Record<ContactIconKey, ContactIcon>;
};

const { locale, contacts, contactIcons } = Astro.props as Props;
const heading = resolveLocalizedText(contactSectionContent.heading, locale);
---
<section
  id="contact"
  class="scroll-fade"
  aria-labelledby="contact-heading"
  data-animate="fade-up"
  data-animate-stagger="90"
  data-animate-translate-y="14px"
  data-animate-duration="420ms"
>
  <div class="section-header section-header--rule">
    <h2 id="contact-heading">{heading}</h2>
    <div class="section-rule" aria-hidden="true"></div>
  </div>
  <ul class="contact-list">
    {contacts.map((contact) => {
      const icon = contact.icon ? contactIcons[contact.icon] : undefined;
      const showLabel = contact.showLabel ?? true;
      return (
        <li class="contact-item" data-animate-item>
          <a
            class={`contact-link surface-card${showLabel ? '' : ' contact-link--compact'}`}
            href={contact.href}
            target={contact.newTab ? '_blank' : undefined}
            rel={contact.newTab ? 'noopener noreferrer' : undefined}
          >
            {icon && (
              <span class="contact-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  {icon.type === 'fill' ? (
                    <path d={icon.d} fill="currentColor" />
                  ) : (
                    <path
                      d={icon.d}
                      fill="none"
                      stroke="currentColor"
                      stroke-width={icon.strokeWidth}
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  )}
                </svg>
              </span>
            )}
            {showLabel && (
              <span class="contact-label">{resolveLocalizedText(contact.label, locale)}</span>
            )}
            <span class="contact-value">{contact.displayValue ?? contact.value}</span>
          </a>
        </li>
      );
    })}
  </ul>
</section>

<style>
  .contact-list {
    display: grid;
    gap: 0.75rem;
  }

  .contact-link {
    display: grid;
    grid-template-columns: 1.25rem minmax(2.8rem, 3.2rem) minmax(0, 1fr);
    gap: 0.9rem;
    align-items: center;
    padding: 0.95rem 1rem;
    background: rgba(255, 255, 255, 0.78);
    color: var(--text);
    text-decoration: none;
    transition: background-color 160ms ease, color 160ms ease, transform 160ms ease;
  }

  .contact-link:hover,
  .contact-link:focus-visible {
    color: var(--accent);
    background: rgba(255, 255, 255, 0.96);
    transform: translateY(-1px);
  }

  .contact-icon {
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .contact-icon svg {
    width: 1rem;
    height: 1rem;
  }

  .contact-label {
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
  }

  .contact-value {
    min-width: 0;
    overflow-wrap: anywhere;
    color: var(--text);
    font-size: 1.02rem;
    font-weight: 600;
    text-decoration: none;
  }

  .contact-link:hover .contact-value,
  .contact-link:focus-visible .contact-value {
    color: var(--accent);
  }

  .contact-link--compact {
    grid-template-columns: 1.25rem max-content;
    justify-content: start;
  }

  .contact-link--compact .contact-value {
    overflow-wrap: normal;
    word-break: normal;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .contact-link {
      grid-template-columns: 1.25rem minmax(0, 1fr);
      grid-template-areas:
        'icon label'
        'icon value';
      align-items: start;
      gap: 0.15rem 0.75rem;
      padding: 1rem 0.95rem;
    }

    .contact-icon {
      grid-area: icon;
      margin-top: 0.2rem;
    }

    .contact-label {
      grid-area: label;
    }

    .contact-value {
      grid-area: value;
      font-size: 0.98rem;
      line-height: 1.6;
    }

    .contact-link--compact {
      grid-template-columns: 1.25rem max-content;
      grid-template-areas: 'icon value';
      align-items: center;
      gap: 0.15rem 0.85rem;
    }
  }

  @media (max-width: 420px) {
    .contact-list {
      gap: 0.65rem;
    }

    .contact-link {
      padding: 0.92rem 0.85rem;
    }
  }
</style>
