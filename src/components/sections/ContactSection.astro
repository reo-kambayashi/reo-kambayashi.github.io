---
import {
  contactSectionContent,
  resolveLocalizedText,
  type Contact,
  type ContactIcon,
  type ContactIconKey,
  type Locale,
} from '../../data/profile';

type Props = {
  locale: Locale;
  contacts: Contact[];
  contactIcons: Record<ContactIconKey, ContactIcon>;
};

const { locale, contacts, contactIcons } = Astro.props as Props;
const heading = resolveLocalizedText(contactSectionContent.heading, locale);
---
<section
  id="contact"
  class="scroll-fade"
  aria-labelledby="contact-heading"
  data-animate="fade-up"
  data-animate-stagger="90"
  data-animate-translate-y="14px"
  data-animate-duration="420ms"
>
  <div class="section-header section-header--rule">
    <h2 id="contact-heading">{heading}</h2>
    <div class="section-rule" aria-hidden="true"></div>
  </div>
  <ul class="contact-list">
    {contacts.map((contact) => {
      const icon = contact.icon ? contactIcons[contact.icon] : undefined;
      const showLabel = contact.showLabel ?? true;
      return (
        <li class="contact-item" data-animate-item>
          <a
            class={`contact-link${showLabel ? '' : ' contact-link--compact'}`}
            href={contact.href}
            target={contact.newTab ? '_blank' : undefined}
            rel={contact.newTab ? 'noopener noreferrer' : undefined}
          >
            {icon && (
              <span class="contact-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  {icon.type === 'fill' ? (
                    <path d={icon.d} fill="currentColor" />
                  ) : (
                    <path
                      d={icon.d}
                      fill="none"
                      stroke="currentColor"
                      stroke-width={icon.strokeWidth}
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  )}
                </svg>
              </span>
            )}
            {showLabel && (
              <span class="contact-label">{resolveLocalizedText(contact.label, locale)}</span>
            )}
            <span class="contact-value">{contact.displayValue ?? contact.value}</span>
          </a>
        </li>
      );
    })}
  </ul>
</section>

<style>
  .contact-list {
    display: flex;
    flex-direction: column;
  }

  .contact-link {
    display: grid;
    grid-template-columns: 1.1rem minmax(4.5rem, 5rem) minmax(0, 1fr);
    gap: 0.8rem;
    align-items: center;
    padding: 1.1rem 0.75rem;
    margin-left: -0.75rem;
    margin-right: -0.75rem;
    background: none;
    border-radius: 4px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: color 120ms ease, background-color 150ms ease;
  }

  .contact-link:hover {
    background-color: var(--surface-soft);
  }

  .contact-link:hover .contact-value,
  .contact-link:focus-visible .contact-value {
    color: var(--accent);
  }

  .contact-icon {
    color: var(--accent);
    opacity: 0.7;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: opacity 150ms ease;
  }

  .contact-link:hover .contact-icon {
    opacity: 1;
  }

  .contact-icon svg {
    width: clamp(0.95rem, 0.9rem + 0.18vw, 1.12rem);
    height: clamp(0.95rem, 0.9rem + 0.18vw, 1.12rem);
  }

  .contact-label {
    color: var(--muted);
    font-size: clamp(0.84rem, 0.8rem + 0.14vw, 0.94rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .contact-value {
    min-width: 0;
    overflow-wrap: anywhere;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: clamp(0.94rem, 0.9rem + 0.18vw, 1.08rem);
    font-weight: 500;
    text-decoration: none;
  }

  .contact-link--compact {
    grid-template-columns: 1.1rem max-content;
    justify-content: start;
  }

  .contact-link--compact .contact-value {
    overflow-wrap: normal;
    word-break: normal;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .contact-link {
      grid-template-columns: 1.1rem minmax(0, 1fr);
      grid-template-areas:
        'icon label'
        'icon value';
      align-items: start;
      gap: 0.12rem 0.7rem;
    }

    .contact-icon {
      grid-area: icon;
      margin-top: 0.2rem;
    }

    .contact-label {
      grid-area: label;
    }

    .contact-value {
      grid-area: value;
      font-size: 0.93rem;
      line-height: 1.6;
    }

    .contact-link--compact {
      grid-template-columns: 1.1rem max-content;
      grid-template-areas: 'icon value';
      align-items: center;
      gap: 0.12rem 0.8rem;
    }
  }
</style>
