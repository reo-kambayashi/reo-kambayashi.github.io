---
import {
  educationSectionContent,
  resolveLocalizedText,
  type Education,
  type Locale,
} from '../../data/profile';

type Props = {
  locale: Locale;
  educationHistory: Education[];
};

const { locale, educationHistory } = Astro.props as Props;
const timelineItems = [...educationHistory].reverse();
const heading = resolveLocalizedText(educationSectionContent.heading, locale);
---
<section
  id="education"
  class="scroll-fade"
  aria-labelledby="education-heading"
  data-animate="fade-up"
  data-animate-stagger="90"
  data-animate-translate-y="14px"
  data-animate-duration="420ms"
>
  <div class="section-header section-header--rule">
    <h2 id="education-heading">{heading}</h2>
    <div class="section-rule" aria-hidden="true"></div>
  </div>
  <ol class="timeline">
    {timelineItems.map((history) => (
      <li class="timeline-item" data-animate-item>
        <div class="timeline-marker" aria-hidden="true">
          <span class="timeline-dot"></span>
        </div>
        <div class="timeline-body">
          <time class="timeline-period">{resolveLocalizedText(history.period, locale)}</time>
          <p class="timeline-desc">{resolveLocalizedText(history.description, locale)}</p>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .timeline {
    --timeline-axis: 0.75rem;
    --timeline-marker-size: 0.65rem;
    position: relative;
    display: grid;
    gap: 0;
    margin-top: 0.15rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    top: 0.5rem;
    bottom: 0.5rem;
    left: calc(var(--timeline-axis) + (var(--timeline-marker-size) / 2) - 0.5px);
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--border) 15%,
      var(--border) 85%,
      transparent 100%
    );
  }

  .timeline-item {
    display: grid;
    grid-template-columns: calc(var(--timeline-axis) + var(--timeline-marker-size)) minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--border);
  }

  .timeline-item:first-child {
    padding-top: 0.2rem;
  }

  .timeline-marker {
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
    padding-top: 0.38rem;
    padding-left: var(--timeline-axis);
    z-index: 1;
  }

  .timeline-dot {
    width: var(--timeline-marker-size);
    height: var(--timeline-marker-size);
    border-radius: 999px;
    background: var(--paper);
    border: 2px solid var(--accent);
    position: relative;
    outline: 3px solid var(--paper);
  }

  .timeline-item:last-child .timeline-dot {
    background: var(--accent);
    border: none;
    outline: 3px solid var(--paper);
  }

  .timeline-item:last-child .timeline-period {
    color: var(--accent);
    font-weight: 600;
  }

  .timeline-body {
    display: grid;
    gap: 0.2rem;
    padding: 0;
  }

  .timeline-period {
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: clamp(0.8rem, 0.76rem + 0.12vw, 0.9rem);
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.5;
  }

  .timeline-desc {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(0.96rem, 0.9rem + 0.2vw, 1.1rem);
    font-weight: 500;
    line-height: 1.7;
  }

  @media (max-width: 520px) {
    .timeline-item {
      gap: 0.75rem;
      padding: 1rem 0;
    }

    .timeline-desc {
      font-size: 0.93rem;
    }
  }
</style>
