---
import {
  educationSectionContent,
  resolveLocalizedText,
  type Education,
  type Locale,
} from '../../data/profile';

type Props = {
  locale: Locale;
  educationHistory: Education[];
};

const { locale, educationHistory } = Astro.props as Props;
const timelineItems = [...educationHistory].reverse();
const heading = resolveLocalizedText(educationSectionContent.heading, locale);
---
<section
  id="education"
  class="scroll-fade"
  aria-labelledby="education-heading"
  data-animate="fade-up"
  data-animate-stagger="90"
  data-animate-translate-y="14px"
  data-animate-duration="420ms"
>
  <div class="section-header section-header--rule">
    <h2 id="education-heading">{heading}</h2>
    <div class="section-rule" aria-hidden="true"></div>
  </div>
  <ol class="timeline">
    {timelineItems.map((history) => (
      <li class="timeline-item" data-animate-item>
        <div class="timeline-marker" aria-hidden="true">
          <span class="timeline-dot"></span>
        </div>
        <div class="timeline-body surface-card">
          <time class="timeline-period">{resolveLocalizedText(history.period, locale)}</time>
          <p class="timeline-desc">{resolveLocalizedText(history.description, locale)}</p>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .timeline {
    --timeline-axis: 1rem;
    --timeline-marker-size: 1.28rem;
    position: relative;
    display: grid;
    gap: 1.25rem;
    margin-top: 0.15rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    top: 0.9rem;
    bottom: 0.9rem;
    left: calc(var(--timeline-axis) + (var(--timeline-marker-size) / 2) - 1px);
    width: 2px;
    background: rgba(31, 35, 40, 0.12);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: calc(var(--timeline-axis) + var(--timeline-marker-size)) minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .timeline-marker {
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
    padding-top: 0.55rem;
    padding-left: var(--timeline-axis);
    z-index: 1;
  }

  .timeline-dot {
    width: var(--timeline-marker-size);
    height: var(--timeline-marker-size);
    border-radius: 999px;
    border: 2px solid var(--accent);
    background: var(--paper);
    position: relative;
    outline: 0.3rem solid rgba(247, 250, 255, 0.98);
  }

  .timeline-dot::after {
    content: '';
    position: absolute;
    inset: 0.19rem;
    border-radius: 999px;
    background: var(--accent);
  }

  .timeline-body {
    display: grid;
    gap: 0.24rem;
    padding: 1rem 1.1rem;
  }

  .timeline-period {
    color: var(--text-strong);
    font-size: 0.98rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.55;
  }

  .timeline-desc {
    margin: 0;
    color: var(--text);
    font-size: 0.98rem;
    line-height: 1.75;
  }

  @media (max-width: 760px) {
    .timeline {
      --timeline-axis: 0.92rem;
      --timeline-marker-size: 1.18rem;
      gap: 1rem;
    }

    .timeline-item {
      grid-template-columns: calc(var(--timeline-axis) + var(--timeline-marker-size)) minmax(0, 1fr);
      gap: 0.9rem;
    }

    .timeline-dot::after {
      inset: 0.18rem;
    }

    .timeline-body {
      padding: 0.9rem 0.95rem;
    }
  }

  @media (max-width: 520px) {
    .timeline {
      --timeline-axis: 0.72rem;
      --timeline-marker-size: 1.06rem;
      gap: 0.85rem;
    }

    .timeline-item {
      grid-template-columns: calc(var(--timeline-axis) + var(--timeline-marker-size)) minmax(0, 1fr);
      gap: 0.72rem;
    }

    .timeline-marker {
      padding-top: 0.56rem;
    }

    .timeline-dot {
      outline-width: 0.24rem;
    }

    .timeline-dot::after {
      inset: 0.17rem;
    }

    .timeline-body {
      gap: 0.2rem;
      padding: 0.82rem 0.85rem;
    }

    .timeline-period,
    .timeline-desc {
      font-size: 0.93rem;
    }
  }
</style>
