---
import {
  layoutContent,
  resolveLocalizedText,
  sectionLinks,
  type Locale,
} from '../data/profile';
import ScrollFadeScript from '../components/scripts/ScrollFadeScript.astro';
import SiteFooter from '../components/SiteFooter.astro';

type Props = {
  locale: Locale;
  title: string;
  description: string;
};

const { locale, title, description } = Astro.props as Props;
const localizedSectionLinks = sectionLinks.map((link) => ({
  ...link,
  label: resolveLocalizedText(link.label, locale),
}));
const navAriaLabel = resolveLocalizedText(layoutContent.navAriaLabel, locale);
const languageSwitcherLabel = resolveLocalizedText(layoutContent.languageSwitcherLabel, locale);
const japaneseLabel = resolveLocalizedText(layoutContent.japaneseLabel, locale);
const englishLabel = resolveLocalizedText(layoutContent.englishLabel, locale);
const basePath = import.meta.env.BASE_URL;
const japanesePath = basePath;
const englishPath = `${basePath.replace(/\/$/, '')}/en`;
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --font-sans: "Noto Sans JP", "Hiragino Sans", "Yu Gothic", system-ui, sans-serif;
        --font-serif: "Noto Serif JP", "Hiragino Mincho ProN", "Yu Mincho", serif;
        --page-bg: #f5f3ef;
        --paper: #fdfcfa;
        --surface: #f0ede8;
        --surface-soft: #f7f5f1;
        --section-surface: #fdfcfa;
        --section-surface-alt: #f7f5f1;
        --text: #2c2c2c;
        --text-strong: #1a1a1a;
        --muted: #7a756d;
        --accent: #3d5a80;
        --accent-strong: #2c4a6e;
        --accent-light: #e8eff5;
        --border: #e4dfd8;
        --surface-border: #ddd8d0;
        --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.04);
        --shadow-md: 0 2px 8px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0, 0, 0, 0.04);
        --shadow-lg: 0 4px 24px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
        --max-width: 820px;
        --page-gutter: clamp(0.75rem, 2vw, 1.5rem);
        --section-px: clamp(1.6rem, 4vw, 3.2rem);
        --section-py: clamp(2rem, 4vw, 3.2rem);
        --section-gap: clamp(1.4rem, 2.5vw, 2rem);
        --font-size-base: clamp(1rem, 0.96rem + 0.16vw, 1.06rem);
        --line-height: 1.9;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      html {
        background: var(--page-bg);
        scroll-behavior: smooth;
      }

      body {
        min-height: 100dvh;
        background: var(--page-bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: var(--font-size-base);
        line-height: var(--line-height);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        padding: var(--page-gutter);
      }

      main.wrap {
        max-width: var(--max-width);
        margin: 0 auto;
        background: var(--paper);
        box-shadow: var(--shadow-md);
        border-radius: 2px;
        position: relative;
        display: flex;
        flex-direction: column;
      }

      section {
        display: flex;
        flex-direction: column;
        gap: var(--section-gap);
        padding: var(--section-py) var(--section-px);
        position: relative;
        scroll-margin-top: 6rem;
      }

      section + section {
        border-top: 1px solid var(--border);
        border-top-color: rgba(228, 223, 216, 0.5);
      }

      h1,
      h2,
      h3,
      p,
      ul,
      ol {
        margin: 0;
      }

      h1 {
        font-family: var(--font-serif);
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: 0.01em;
        color: var(--text-strong);
      }

      h2 {
        font-family: var(--font-sans);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--muted);
      }

      h3 {
        font-family: var(--font-serif);
        font-size: clamp(1rem, 0.96rem + 0.2vw, 1.1rem);
        font-weight: 600;
        line-height: 1.6;
        color: var(--text-strong);
        margin: 0;
      }

      p,
      li,
      dd,
      dt,
      time {
        line-height: var(--line-height);
      }

      p {
        text-wrap: pretty;
      }

      a {
        color: var(--accent);
        text-decoration-thickness: 1px;
        text-underline-offset: 0.18em;
        text-decoration-color: transparent;
        transition: color 150ms ease, text-decoration-color 150ms ease;
      }

      a:hover,
      a:focus-visible {
        color: var(--accent-strong);
        text-decoration-color: currentColor;
      }

      a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }

      ul,
      ol {
        padding: 0;
        margin: 0;
        list-style: none;
      }

      li {
        padding: 0;
      }

      img,
      svg {
        display: block;
        max-width: 100%;
      }

      .section-header {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.95rem 1.15rem;
      }

      .section-header--rule {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        gap: 1rem;
      }

      .section-rule {
        height: 1px;
        background: var(--border);
      }

      .surface-card {
        background: transparent;
        border-radius: 0;
        border-bottom: 1px solid var(--border);
      }

      .js .scroll-fade {
        opacity: 0;
        transform: translate3d(var(--animate-translate-x, 0px), var(--animate-translate-y, 16px), 0)
          scale(var(--animate-scale, 1));
        transition:
          opacity var(--animate-duration-opacity, 420ms) var(--animate-ease-opacity, ease-out)
            var(--animate-delay, 0ms),
          transform var(--animate-duration, 480ms)
            var(--animate-ease-transform, cubic-bezier(0.22, 0.61, 0.36, 1))
            var(--animate-delay, 0ms);
        will-change: transform, opacity;
      }

      .js .scroll-fade.is-visible {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1);
        will-change: auto;
      }

      .js .scroll-fade [data-animate-item] {
        opacity: 0;
        transform: translate3d(0, 10px, 0);
        transition:
          opacity var(--animate-child-duration, 340ms)
            var(--animate-child-easing, cubic-bezier(0.22, 0.61, 0.36, 1))
            var(--animate-child-delay, 0ms),
          transform var(--animate-child-duration, 340ms)
            var(--animate-child-easing, cubic-bezier(0.22, 0.61, 0.36, 1))
            var(--animate-child-delay, 0ms);
      }

      .js .scroll-fade.is-visible [data-animate-item] {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }

      .site-nav-shell {
        position: sticky;
        top: 0;
        z-index: 10;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 var(--page-gutter);
        backdrop-filter: blur(12px);
        background: rgba(253, 252, 250, 0.92);
        border-bottom: 1px solid var(--border);
        box-shadow: 0 1px 8px rgba(0, 0, 0, 0.04);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .language-switcher {
        display: flex;
        flex-shrink: 0;
        order: 2;
      }

      .language-switcher-inner {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
      }

      .language-link {
        display: inline-flex;
        align-items: center;
        padding: 0.45rem 0.5rem;
        color: var(--muted);
        font-family: var(--font-sans);
        font-size: 0.75rem;
        font-weight: 500;
        text-decoration: none;
        letter-spacing: 0.08em;
        transition: color 120ms ease;
      }

      .language-link:hover,
      .language-link:focus-visible {
        color: var(--text-strong);
      }

      .language-link.is-current {
        color: var(--text-strong);
        font-weight: 700;
      }

      .language-divider {
        color: var(--border);
        font-size: 0.75rem;
        user-select: none;
      }

      .site-nav {
        display: flex;
        order: 1;
        flex: 1;
        min-width: 0;
      }

      .nav-list {
        display: flex;
        flex-wrap: nowrap;
        gap: 0;
        padding: 0;
        background: none;
        overflow-x: auto;
        scrollbar-width: none;
      }

      .nav-list::-webkit-scrollbar {
        display: none;
      }

      .nav-item {
        flex: 0 0 auto;
      }

      .nav-link {
        color: var(--muted);
        text-decoration: none;
        font-family: var(--font-sans);
        font-size: 0.82rem;
        font-weight: 500;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        min-height: 2.6rem;
        padding: 0 0.85rem 0 0;
        transition: color 120ms ease;
        position: relative;
      }

      .nav-link::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0.85rem;
        height: 2px;
        background: var(--accent);
        border-radius: 1px;
        transform: scaleX(0);
        transition: transform 200ms ease;
      }

      .nav-link:hover,
      .nav-link:focus-visible {
        color: var(--text-strong);
      }

      .nav-link:hover::after {
        transform: scaleX(1);
      }

      .nav-link.is-active {
        color: var(--text-strong);
        font-weight: 700;
      }

      .nav-link.is-active::after {
        transform: scaleX(1);
      }

      @media (max-width: 640px) {
        :root {
          --page-gutter: 0.6rem;
          --section-px: 1.1rem;
          --section-py: 1.6rem;
          --section-gap: 1.1rem;
          --font-size-base: 0.95rem;
        }

        body {
          padding: var(--page-gutter);
        }

        .site-nav-shell {
          padding: 0 var(--page-gutter);
        }

        .nav-link {
          min-height: 2.75rem;
          padding-right: 0.7rem;
          font-size: 0.8rem;
        }

        .language-link {
          font-size: 0.72rem;
        }

        .section-header--rule {
          gap: 0.7rem;
        }
      }

      @media (max-width: 520px) {
        .section-header--rule {
          grid-template-columns: 1fr;
          gap: 0.5rem;
        }

        .section-rule {
          width: 100%;
        }
      }

      @media (max-width: 420px) {
        :root {
          --page-gutter: 0.3rem;
          --section-px: 0.85rem;
          --section-py: 1.05rem;
        }
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: -1;
        opacity: 0.015;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 256px 256px;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        .js .scroll-fade,
        .js .scroll-fade [data-animate-item] {
          opacity: 1;
          transform: none;
          transition: none;
          will-change: auto;
        }

        a,
        .nav-link::after {
          transition: none !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="site-nav-shell">
      <div class="language-switcher" role="group" aria-label={languageSwitcherLabel}>
        <div class="language-switcher-inner">
          {locale === 'ja' ? (
            <>
              <span class="language-link is-current" lang="ja" aria-current="page">
                {japaneseLabel}
              </span>
              <span class="language-divider" aria-hidden="true">/</span>
              <a class="language-link" href={englishPath} lang="en">
                {englishLabel}
              </a>
            </>
          ) : (
            <>
              <a class="language-link" href={japanesePath} lang="ja">
                {japaneseLabel}
              </a>
              <span class="language-divider" aria-hidden="true">/</span>
              <span class="language-link is-current" lang="en" aria-current="page">
                {englishLabel}
              </span>
            </>
          )}
        </div>
      </div>
      <nav class="site-nav" aria-label={navAriaLabel}>
        <ul class="nav-list">
          {localizedSectionLinks.map((link, index) => (
            <li class="nav-item">
              <a
                href={link.href}
                class:list={['nav-link', index === 0 && 'is-active']}
                aria-current={index === 0 ? 'location' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
    <main class="wrap">
      <slot />
    </main>
    <SiteFooter />
    <slot name="scripts" />
    <ScrollFadeScript />
    <script is:inline>
      const initSectionNav = () => {
        const links = Array.from(document.querySelectorAll('.nav-link'));
        const nav = document.querySelector('.site-nav-shell');
        const sectionMap = new Map(
          links.map((link) => {
            const href = link.getAttribute('href') ?? '';
            return [href.replace('#', ''), link];
          })
        );
        const sections = Array.from(document.querySelectorAll('main.wrap section[id]')).filter((section) =>
          sectionMap.has(section.id)
        );

        if (!links.length || !sections.length) {
          return;
        }

        let frameId = 0;

        const setActive = (id) => {
          links.forEach((link) => {
            const isActive = link.getAttribute('href') === `#${id}`;
            link.classList.toggle('is-active', isActive);
            if (isActive) {
              link.setAttribute('aria-current', 'location');
            } else {
              link.removeAttribute('aria-current');
            }
          });
        };

        const getReferenceLine = () => {
          const navRect = nav instanceof HTMLElement ? nav.getBoundingClientRect() : null;
          const navBottom = navRect ? navRect.bottom : 0;
          return navBottom + 24;
        };

        const getActiveSectionId = () => {
          const referenceLine = getReferenceLine();
          let activeSection = sections[0];
          let closestSection = sections[0];
          let closestDistance = Number.POSITIVE_INFINITY;

          sections.forEach((section) => {
            const rect = section.getBoundingClientRect();
            const topDistance = Math.abs(rect.top - referenceLine);

            if (topDistance < closestDistance) {
              closestDistance = topDistance;
              closestSection = section;
            }

            if (rect.top <= referenceLine && rect.bottom > referenceLine) {
              activeSection = section;
            }
          });

          const nearBottom =
            window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2;

          if (nearBottom) {
            return sections[sections.length - 1].id;
          }

          return (activeSection ?? closestSection).id;
        };

        const syncActiveSection = () => {
          frameId = 0;
          setActive(getActiveSectionId());
        };

        const scheduleSync = () => {
          if (frameId) {
            return;
          }

          frameId = window.requestAnimationFrame(syncActiveSection);
        };

        const hash = window.location.hash.replace('#', '');
        if (hash && sectionMap.has(hash)) {
          setActive(hash);
        } else {
          setActive(sections[0].id);
          scheduleSync();
        }

        window.addEventListener('scroll', scheduleSync, { passive: true });
        window.addEventListener('resize', scheduleSync, { passive: true });
        window.addEventListener('load', scheduleSync, { once: true });
        window.addEventListener('hashchange', () => {
          const currentHash = window.location.hash.replace('#', '');
          if (currentHash && sectionMap.has(currentHash)) {
            setActive(currentHash);
            scheduleSync();
            return;
          }

          scheduleSync();
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSectionNav, { once: true });
      } else {
        initSectionNav();
      }
    </script>
  </body>
</html>
