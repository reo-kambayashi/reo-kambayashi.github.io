---
import { sectionLinks } from '../data/profile';

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props as Props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --font-sans: "Noto Sans JP", "Hiragino Sans", "Yu Gothic", system-ui, sans-serif;
        --font-serif: "Noto Serif JP", "Hiragino Mincho ProN", "Yu Mincho", serif;
        --page-bg: #eaf1fb;
        --paper: rgba(255, 255, 255, 0.94);
        --surface: rgba(247, 250, 255, 0.94);
        --surface-soft: rgba(255, 255, 255, 0.99);
        --section-surface: rgba(251, 253, 255, 0.94);
        --section-surface-alt: rgba(246, 250, 255, 0.92);
        --text: #1f2328;
        --text-strong: #14181d;
        --muted: #5f6f88;
        --accent: #3d6fb4;
        --accent-strong: #2755a5;
        --border: rgba(31, 35, 40, 0.08);
        --surface-border: rgba(31, 35, 40, 0.06);
        --max-width: 1120px;
        --page-gutter: clamp(0.75rem, 2vw, 1.5rem);
        --section-px: clamp(1.4rem, 4vw, 3.25rem);
        --section-py: clamp(1.5rem, 3.6vw, 2.6rem);
        --section-gap: clamp(0.9rem, 2vw, 1.25rem);
        --font-size-base: clamp(0.96rem, 0.94rem + 0.16vw, 1.02rem);
        --line-height: 1.9;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      html {
        background: var(--page-bg);
        scroll-behavior: smooth;
      }

      body {
        min-height: 100vh;
        background: var(--page-bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: var(--font-size-base);
        line-height: var(--line-height);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        padding: var(--page-gutter);
      }

      main.wrap {
        max-width: var(--max-width);
        margin: 0 auto;
        background: var(--paper);
        border-radius: 24px;
        overflow: hidden;
        position: relative;
        display: flex;
        flex-direction: column;
      }

      section {
        display: flex;
        flex-direction: column;
        gap: var(--section-gap);
        padding: var(--section-py) var(--section-px);
        position: relative;
        scroll-margin-top: 6rem;
      }

      main.wrap > section:not(.hero) {
        background: var(--section-surface);
      }

      main.wrap > section:nth-child(odd):not(.hero) {
        background: var(--section-surface-alt);
      }

      section + section {
        border-top: 1px solid var(--border);
      }

      h1,
      h2,
      h3,
      p,
      ul,
      ol {
        margin: 0;
      }

      h1 {
        font-family: var(--font-serif);
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: 0.01em;
        color: var(--text-strong);
      }

      h2 {
        display: inline-flex;
        align-items: center;
        gap: 0.65rem;
        font-size: 0.98rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        color: var(--text-strong);
      }

      h2::before {
        content: '';
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 999px;
        background: rgba(61, 111, 180, 0.16);
        border: 1px solid rgba(61, 111, 180, 0.34);
      }

      p,
      li,
      dd,
      dt,
      time {
        line-height: var(--line-height);
      }

      p {
        text-wrap: pretty;
      }

      a {
        color: var(--accent);
        text-decoration-thickness: 1px;
        text-underline-offset: 0.18em;
      }

      a:hover,
      a:focus-visible {
        color: var(--accent-strong);
      }

      a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }

      ul,
      ol {
        padding: 0;
        margin: 0;
        list-style: none;
      }

      li {
        padding: 0;
      }

      img,
      svg {
        display: block;
        max-width: 100%;
      }

      .section-header {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.95rem 1.15rem;
      }

      .section-header--rule {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        gap: 1rem;
      }

      .section-rule {
        height: 1px;
        background: linear-gradient(90deg, rgba(31, 35, 40, 0.12), rgba(31, 35, 40, 0.04));
      }

      .surface-card {
        background: var(--surface-soft);
        border-radius: 18px;
      }

      .site-nav {
        position: sticky;
        top: 0.4rem;
        z-index: 10;
        max-width: var(--max-width);
        margin: 0 auto 0.9rem;
        padding: 0.9rem var(--page-gutter) 0.6rem;
        backdrop-filter: blur(8px);
      }

      .nav-list {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.4rem;
        padding: 0.45rem;
        background: rgba(255, 255, 255, 0.84);
        border-radius: 999px;
        width: fit-content;
        max-width: 100%;
        margin: 0 auto;
      }

      .nav-item {
        flex: 0 0 auto;
      }

      .nav-link {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.94rem;
        font-weight: 600;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.45rem;
        padding: 0.35rem 0.95rem;
        border-radius: 999px;
        transition: background-color 160ms ease, color 160ms ease;
      }

      .nav-link:hover,
      .nav-link:focus-visible {
        background: rgba(61, 111, 180, 0.1);
        color: var(--accent-strong);
      }

      .nav-link.is-active {
        background: rgba(61, 111, 180, 0.16);
        color: var(--accent-strong);
      }

      @media (max-width: 640px) {
        :root {
          --page-gutter: 0.45rem;
          --section-px: 1rem;
          --section-py: 1.2rem;
          --section-gap: 0.8rem;
          --font-size-base: 0.95rem;
        }

        body {
          padding: var(--page-gutter);
        }

        main.wrap {
          border-radius: 18px;
        }

        .site-nav {
          top: 0;
          margin-bottom: 0.6rem;
          padding: 0.45rem 0 0.35rem;
        }

        .nav-list {
          width: 100%;
          justify-content: flex-start;
          flex-wrap: nowrap;
          gap: 0.3rem;
          padding: 0.35rem;
          border-radius: 18px;
          overflow-x: auto;
          overscroll-behavior-x: contain;
          -webkit-overflow-scrolling: touch;
          scrollbar-width: none;
        }

        .nav-list::-webkit-scrollbar {
          display: none;
        }

        .nav-link {
          min-height: 2.3rem;
          padding: 0.35rem 0.85rem;
          font-size: 0.89rem;
        }

        .section-header--rule {
          gap: 0.7rem;
        }
      }

      @media (max-width: 520px) {
        .section-header--rule {
          grid-template-columns: 1fr;
          gap: 0.5rem;
        }

        .section-rule {
          width: 100%;
        }
      }

      @media (max-width: 420px) {
        :root {
          --page-gutter: 0.3rem;
          --section-px: 0.85rem;
          --section-py: 1.05rem;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }
    </style>
  </head>
  <body>
    <nav class="site-nav" aria-label="ページ内ナビゲーション">
      <ul class="nav-list">
        {sectionLinks.map((link, index) => (
          <li class="nav-item">
            <a
              href={link.href}
              class:list={['nav-link', index === 0 && 'is-active']}
              aria-current={index === 0 ? 'location' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <main class="wrap">
      <slot />
    </main>
    <slot name="scripts" />
    <script is:inline>
      const initSectionNav = () => {
        const links = Array.from(document.querySelectorAll('.nav-link'));
        const sectionMap = new Map(
          links.map((link) => {
            const href = link.getAttribute('href') ?? '';
            return [href.replace('#', ''), link];
          })
        );
        const sections = Array.from(document.querySelectorAll('main.wrap section[id]')).filter((section) =>
          sectionMap.has(section.id)
        );

        if (!links.length || !sections.length) {
          return;
        }

        const setActive = (id) => {
          links.forEach((link) => {
            const isActive = link.getAttribute('href') === `#${id}`;
            link.classList.toggle('is-active', isActive);
            if (isActive) {
              link.setAttribute('aria-current', 'location');
            } else {
              link.removeAttribute('aria-current');
            }
          });
        };

        const hash = window.location.hash.replace('#', '');
        setActive(hash || sections[0].id);

        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

            if (visible) {
              setActive(visible.target.id);
            }
          },
          {
            rootMargin: '-30% 0px -48% 0px',
            threshold: [0.2, 0.35, 0.6],
          }
        );

        sections.forEach((section) => observer.observe(section));
        window.addEventListener('hashchange', () => {
          const currentHash = window.location.hash.replace('#', '');
          if (currentHash) {
            setActive(currentHash);
          }
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSectionNav, { once: true });
      } else {
        initSectionNav();
      }
    </script>
  </body>
</html>
