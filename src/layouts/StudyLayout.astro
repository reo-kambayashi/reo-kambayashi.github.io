---
type Props = {
  title: string;
  description: string;
  activePath?: 'list' | 'article';
};

const { title, description } = Astro.props as Props;
const basePath = import.meta.env.BASE_URL;
const profilePath = basePath;
const listPath = `${basePath.replace(/\/$/, '')}/study/competitive-programming`;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Noto+Serif+JP:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --font-sans: "Noto Sans JP", "Hiragino Sans", "Yu Gothic", system-ui, sans-serif;
        --font-serif: "Noto Serif JP", "Hiragino Mincho ProN", "Yu Mincho", serif;
        --page-bg: #f5f3ef;
        --paper: #fdfcfa;
        --surface: #f0ede8;
        --surface-soft: #f7f5f1;
        --section-surface: #fdfcfa;
        --section-surface-alt: #f7f5f1;
        --text: #2c2c2c;
        --text-strong: #1a1a1a;
        --muted: #7a756d;
        --accent: #3d5a80;
        --accent-strong: #2c4a6e;
        --accent-light: #e8eff5;
        --border: #e4dfd8;
        --surface-border: #ddd8d0;
        --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.04);
        --shadow-md: 0 2px 8px rgba(0, 0, 0, 0.06), 0 1px 3px rgba(0, 0, 0, 0.04);
        --shadow-lg: 0 4px 24px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
        --max-width: 820px;
        --page-gutter: clamp(0.75rem, 2vw, 1.5rem);
        --section-px: clamp(1.6rem, 4vw, 3.2rem);
        --section-py: clamp(2rem, 4vw, 3.2rem);
        --section-gap: clamp(1.4rem, 2.5vw, 2rem);
        --font-size-base: clamp(1rem, 0.96rem + 0.16vw, 1.06rem);
        --line-height: 1.9;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      html {
        background: var(--page-bg);
        scroll-behavior: smooth;
      }

      body {
        min-height: 100dvh;
        background: var(--page-bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: var(--font-size-base);
        line-height: var(--line-height);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        padding: var(--page-gutter);
      }

      main.wrap {
        max-width: var(--max-width);
        margin: 0 auto;
        background: var(--paper);
        box-shadow: var(--shadow-md);
        border-radius: 2px;
        position: relative;
        display: flex;
        flex-direction: column;
      }

      section {
        display: flex;
        flex-direction: column;
        gap: var(--section-gap);
        padding: var(--section-py) var(--section-px);
        position: relative;
      }

      section + section {
        border-top: 1px solid var(--border);
        border-top-color: rgba(228, 223, 216, 0.5);
      }

      h1,
      h2,
      h3,
      p,
      ul,
      ol {
        margin: 0;
      }

      h1 {
        font-family: var(--font-serif);
        font-size: clamp(1.6rem, 3vw, 2.2rem);
        font-weight: 600;
        line-height: 1.3;
        letter-spacing: 0.01em;
        color: var(--text-strong);
      }

      h2 {
        font-family: var(--font-sans);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--muted);
      }

      h3 {
        font-family: var(--font-serif);
        font-size: clamp(1.05rem, 1rem + 0.2vw, 1.2rem);
        font-weight: 600;
        line-height: 1.5;
        color: var(--text-strong);
        margin: 0;
      }

      p,
      li,
      dd,
      dt,
      time {
        line-height: var(--line-height);
      }

      p {
        text-wrap: pretty;
      }

      a {
        color: var(--accent);
        text-decoration-thickness: 1px;
        text-underline-offset: 0.18em;
        text-decoration-color: transparent;
        transition: color 150ms ease, text-decoration-color 150ms ease;
      }

      a:hover,
      a:focus-visible {
        color: var(--accent-strong);
        text-decoration-color: currentColor;
      }

      a:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
      }

      ul,
      ol {
        padding: 0;
        margin: 0;
        list-style: none;
      }

      img,
      svg {
        display: block;
        max-width: 100%;
      }

      .study-breadcrumb {
        max-width: var(--max-width);
        margin: 0 auto 0.75rem;
        padding: 0 var(--page-gutter);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.4rem 0.6rem;
        font-size: 0.8rem;
        color: var(--muted);
      }

      .study-breadcrumb a {
        color: var(--muted);
      }

      .study-breadcrumb a:hover,
      .study-breadcrumb a:focus-visible {
        color: var(--text-strong);
      }

      .study-breadcrumb-sep {
        color: var(--border);
        user-select: none;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: -1;
        opacity: 0.015;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-size: 256px 256px;
      }

      @media (max-width: 640px) {
        :root {
          --page-gutter: 0.6rem;
          --section-px: 1.1rem;
          --section-py: 1.6rem;
          --section-gap: 1.1rem;
          --font-size-base: 0.95rem;
        }

        body {
          padding: var(--page-gutter);
        }
      }

      @media (max-width: 420px) {
        :root {
          --page-gutter: 0.3rem;
          --section-px: 0.85rem;
          --section-py: 1.05rem;
        }
      }
    </style>
  </head>
  <body>
    <nav class="study-breadcrumb" aria-label="パンくず">
      <a href={profilePath}>プロフィールへ</a>
      <span class="study-breadcrumb-sep" aria-hidden="true">/</span>
      <a href={listPath}>競技プログラミング勉強ノート</a>
    </nav>
    <main class="wrap">
      <slot />
    </main>
  </body>
</html>
